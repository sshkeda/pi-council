{
  "name": "pi-council",
  "version": "0.1.0",
  "description": "Multi-model AI council — spawn Claude, GPT, Gemini, and Grok as parallel coding agents to get independent opinions. CLI + pi extension.",
  "author": "sshkeda",
  "license": "MIT",
  "type": "module",
  "bin": {
    "pi-council": "./bin/pi-council.js"
  },
  "files": [
    "bin",
    "dist",
    "src",
    "skills",
    "extensions",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sshkeda/pi-council.git"
  },
  "homepage": "https://github.com/sshkeda/pi-council#readme",
  "bugs": {
    "url": "https://github.com/sshkeda/pi-council/issues"
  },
  "keywords": [
    "pi-package",
    "ai-council",
    "multi-model",
    "multi-model-ai",
    "parallel-agents",
    "ai-agents",
    "coding-agent",
    "orchestration",
    "agent-orchestration",
    "llm",
    "claude",
    "gpt",
    "gemini",
    "grok",
    "multi-agent",
    "spawn-council",
    "cli",
    "developer-tools"
  ],
  "pi": {
    "skills": [
      "./skills"
    ],
    "extensions": [
      "./extensions"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "rm -rf dist && tsc",
    "dev": "node --import tsx src/cli.ts",
    "test": "node --import tsx --test test/*.test.ts test/scenarios/*.test.ts"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.0.0",
    "@types/node": "^22.0.0",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "@sinclair/typebox": "*"
  },
  "exports": {
    ".": "./dist/src/cli.js",
    "./core/config": "./dist/src/core/config.js",
    "./core/runner": "./dist/src/core/runner.js",
    "./core/stream-parser": "./dist/src/core/stream-parser.js",
    "./core/run-lifecycle": "./dist/src/core/run-lifecycle.js",
    "./core/run-state": "./dist/src/core/run-state.js",
    "./util/pid": "./dist/src/util/pid.js",
    "./util/format": "./dist/src/util/format.js",
    "./util/run-id": "./dist/src/util/run-id.js"
  }
}
