{
  "name": "pi-council",
  "version": "0.1.0",
  "description": "Multi-model AI council — spawn Claude, GPT, Gemini, and Grok as parallel coding agents to get independent opinions. CLI + pi extension.",
  "author": "sshkeda",
  "license": "MIT",
  "type": "module",
  "bin": {
    "pi-council": "./bin/pi-council.js"
  },
  "files": [
    "bin",
    "dist",
    "src",
    "skills",
    "extensions",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sshkeda/pi-council.git"
  },
  "homepage": "https://github.com/sshkeda/pi-council#readme",
  "bugs": {
    "url": "https://github.com/sshkeda/pi-council/issues"
  },
  "keywords": [
    "pi-package",
    "ai-council",
    "multi-model",
    "multi-model-ai",
    "parallel-agents",
    "ai-agents",
    "coding-agent",
    "orchestration",
    "agent-orchestration",
    "llm",
    "claude",
    "gpt",
    "gemini",
    "grok",
    "multi-agent",
    "spawn-council",
    "cli",
    "developer-tools"
  ],
  "pi": {
    "skills": [
      "./skills"
    ],
    "extensions": [
      "./extensions"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "rm -rf dist && tsc",
    "dev": "node --import tsx src/cli.ts",
    "test": "npm run build && node tests/council.test.mjs",
    "test:e2e": "npm run build && node tests/e2e-extension.test.mjs && node tests/e2e-cli.test.mjs",
    "test:e2e:ext": "npm run build && node tests/e2e-extension.test.mjs",
    "test:e2e:cli": "npm run build && node tests/e2e-cli.test.mjs",
    "test:all": "npm run build && node tests/council.test.mjs && node tests/e2e-extension.test.mjs && node tests/e2e-cli.test.mjs"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "pi-mock": "file:../pi-mock"
  }
}
