{
  "name": "pi-council",
  "version": "0.1.0",
  "description": "Spawn different AI models in parallel via pi to get independent opinions",
  "type": "module",
  "bin": {
    "pi-council": "./bin/pi-council.js"
  },
  "files": [
    "bin",
    "dist",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "keywords": ["pi-package"],
  "pi": {
    "skills": ["./skills"]
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "dev": "node --import tsx src/cli.ts"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.0.0",
    "@types/node": "^22.0.0"
  }
}
