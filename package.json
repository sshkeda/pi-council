{
  "name": "pi-council",
  "version": "0.1.0",
  "description": "Spawn different AI models in parallel via pi to get independent opinions",
  "type": "module",
  "bin": {
    "pi-council": "./bin/pi-council.js"
  },
  "files": [
    "bin",
    "dist",
    "src",
    "skills",
    "extensions",
    "README.md",
    "LICENSE"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sshkeda/pi-council"
  },
  "homepage": "https://github.com/sshkeda/pi-council",
  "keywords": ["pi-package"],
  "pi": {
    "skills": ["./skills"],
    "extensions": ["./extensions"]
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "rm -rf dist && tsc",
    "dev": "node --import tsx src/cli.ts"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.0.0",
    "@types/node": "^22.0.0",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "@sinclair/typebox": "*"
  }
}
